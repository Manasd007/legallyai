# ──────────────────────────────────────────────────────────────
# Legally AI — environment configuration (copy to backend/.env)
# Free-tier rate limits & model names change often; everything that
# might change lives here so logic never has to be touched. (brief §13)
# ──────────────────────────────────────────────────────────────

# ── LLM providers ────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=

# Model IDs (swap freely; logic reads these, never hardcodes)
ROUTER_MODEL=groq/llama-3.1-8b-instant          # fast intake classifier
REFORMULATE_MODEL=groq/llama-3.1-8b-instant     # cheap query rewriter
REASONING_MODEL=gemini/gemini-2.0-flash         # grounded predict+explain (1M ctx)

# Fallback routing (LiteLLM-style provider/model string used on rate-limit)
LLM_FALLBACK_PROVIDER=openrouter
LLM_FALLBACK_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # backend only — never expose to frontend
SUPABASE_JWT_SECRET=           # backend only — Settings → API → JWT Secret.
                               # Verifies the user's session token so per-user
                               # history is trustworthy. Leave blank for local
                               # dev (auth is skipped; everyone is "dev-user").

# The frontend (Next.js) needs the public Supabase keys too. Put these in
# frontend/.env.local (see frontend/.env.local.example) — NEVER the service key:
#   NEXT_PUBLIC_SUPABASE_URL=
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Retrieval ────────────────────────────────────────────────
EMBEDDING_MODEL=law-ai/InLegalBERT   # 768-dim domain encoder
EMBEDDING_DIM=768
TOP_K=5
SIMILARITY_THRESHOLD=0.35            # below this -> weak-retrieval hedge (§6.5)
VECTOR_BACKEND=faiss                 # faiss | pgvector
FAISS_INDEX_PATH=data/index/corpus.faiss
FAISS_META_PATH=data/index/corpus_meta.parquet

# ── Hugging Face artifacts (prod) ────────────────────────────
# In prod the data/ folder is empty, so the backend downloads the FAISS index
# and the classifier from the Hub. Set HF_NAMESPACE to your HF username and the
# two repo ids are derived automatically (<HF_NAMESPACE>/legally-ai-corpus-index
# and .../legally-ai-predex-classifier). Pin the version tags so a deploy can
# never pick up a half-rebuilt index. Locally, leave HF_NAMESPACE blank — the
# backend uses data/ and never touches the network.
HF_NAMESPACE=                        # e.g. your-hf-username
CORPUS_REVISION=v1                   # dataset repo tag to pull the index from
CLASSIFIER_REVISION=v1               # model repo tag to pull the classifier from
# CORPUS_REPO=                       # optional: override the derived dataset repo id
# CLASSIFIER_REPO=                   # optional: override the derived model repo id

# ── OCR (scanned / handwritten / multilingual uploads) ───────
# Backend: "vision_llm" (default — a multimodal LLM reads the image, free tier,
# no extra setup) or "google_vision" (Google Cloud Vision OCR engine).
OCR_BACKEND=vision_llm
VISION_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct
OCR_MAX_PAGES=8                # max pages OCR'd per PDF (free-tier guard)
OCR_MIN_CHARS=200             # PDFs with less embedded text are treated as scanned

# Google Cloud Vision — only used when OCR_BACKEND=google_vision.
# Vision auth is a service-account JSON file, NOT a simple API key. Create one in
# GCP (project → enable Vision API → service account → JSON key) and point this at
# the file. The Google client library reads this env var automatically.
GOOGLE_APPLICATION_CREDENTIALS=    # e.g. /etc/secrets/gcp-vision.json
OCR_LANGUAGE_HINTS=               # optional, e.g. hi,ta,bn,en — bias scripts; blank = auto

# Translate OCR output to English (Google Vision only transcribes; this makes
# regional-language/handwritten docs usable downstream). Off by default.
OCR_TRANSLATE=false
OCR_TRANSLATE_MODEL=             # blank -> uses REASONING_MODEL

# ── App ──────────────────────────────────────────────────────
CORPUS_DATE_RANGE=Supreme Court of India, ~2015-present   # surfaced in UI (§16)
CACHE_TTL_SECONDS=86400
DISCLAIMER=This is a research/educational tool, not legal advice. It can be wrong or incomplete. Consult a qualified advocate before acting.
