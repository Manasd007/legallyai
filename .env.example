ROUTER_MODEL=groq/llama-3.1-8b-instant          
REFORMULATE_MODEL=groq/llama-3.1-8b-instant    
REASONING_MODEL=gemini/gemini-2.0-flash        

LLM_FALLBACK_PROVIDER=openrouter
LLM_FALLBACK_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          
SUPABASE_JWT_SECRET=           
                               
                              
EMBEDDING_MODEL=law-ai/InLegalBERT  
EMBEDDING_DIM=768
TOP_K=5
SIMILARITY_THRESHOLD=0.35           
FAISS_INDEX_PATH=data/index/corpus.faiss
FAISS_META_PATH=data/index/corpus_meta.parquet


HF_NAMESPACE=                        
