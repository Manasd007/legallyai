# Legally AI — frontend environment (copy to frontend/.env.local)
# Only PUBLIC keys belong here; they ship to the browser. Never put the
# Supabase SERVICE key in this file.

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where to proxy /api/* during local dev (FastAPI backend). Optional.
# BACKEND_URL=http://localhost:8000

# Legally AI Voice service origin, for the mic button in the composer. The browser
# hits this directly rather than through the /api/* rewrite — Next.js rewrites
# don't proxy WebSockets, and WebRTC signalling needs a real origin. Leave unset
# to hide voice entirely.
NEXT_PUBLIC_VOICE_URL=http://localhost:7860
