# Legally AI — frontend environment (copy to frontend/.env.local)
# Only PUBLIC keys belong here; they ship to the browser. Never put the
# Supabase SERVICE key in this file.

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where to proxy /api/* during local dev (FastAPI backend). Optional.
# BACKEND_URL=http://localhost:8000
